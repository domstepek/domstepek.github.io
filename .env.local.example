# Required environment variables for local development
# Copy this file to .env.local and fill in the values
#
# GATE_HASH: SHA-256 hex of the portfolio passcode
#   Compute: echo -n "<your-passcode>" | shasum -a 256
GATE_HASH=

# GATE_TEST_PASSCODE: Plaintext passcode used only in Playwright tests
#   Must match the plaintext behind GATE_HASH
GATE_TEST_PASSCODE=

# NODE_ENV: Set to "development" for local dev
NODE_ENV=
